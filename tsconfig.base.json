{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@vibe-architecture/react": ["packages/react/src/index.ts"],
      "@vibe-architecture/react-headless": ["packages/react-headless/src/index.ts"],
      "@vibe-architecture/css": ["packages/css/index.css"],
      "@vibe-architecture/css/*": ["packages/css/*"]
    }
  }
}
